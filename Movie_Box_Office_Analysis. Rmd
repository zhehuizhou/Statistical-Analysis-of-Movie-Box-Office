    #Ligne vert indique la moyenne
    geom_vline(aes(xintercept = mean({{x_var}}, na.rm = TRUE)), 
               color = "green", linetype = "dashed", linewidth = 1) +
    #Ligne bleu indique la médiane
    geom_vline(aes(xintercept = median({{x_var}}, na.rm = TRUE)), 
               color = "blue", linetype = "dashed", linewidth = 1) +
    scale_x_log10(labels = scales::comma) +
    labs(
      title = title,
      x = x_title,
      y = "Densité"
    ) +
    theme_grey()
}
